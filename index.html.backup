  <!-- FAQ -->
  <section id="faq" class="py-18 bg-white">
    <div class="container mx-auto px-6">
      <div class="max-w-4xl mx-auto text-center mb-12">
        <h2 class="text-3xl md:text-5xl font-black text-zinc-900 mb-4" style="letter-spacing:-0.02em;">
          FAQ
        </h2>
        <p class="text-lg text-zinc-600">Short answers before you try it.</p>
      </div>

      <div class="max-w-4xl mx-auto bg-white border border-zinc-200 rounded-2xl p-8">
        <div class="divide-y">
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false" onclick="toggleFaq(this)">
              <span class="faq-question-text">Do you upload my Zapier export?</span>
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
              <div class="faq-answer-inner">
                No. Relay processes the file <strong>locally in your browser</strong>. There is no upload step and no server-side storage.
              </div>
            </div>
          </div>

          <div class="faq-item">
            <button class="faq-question" aria-expanded="false" onclick="toggleFaq(this)">
              <span class="faq-question-text">When should I use the Audit vs the Continuity Report?</span>
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
              <div class="faq-answer-inner">
                <div class="faq-category-badge bg-blue-50 text-blue-700 border border-blue-200">AUDIT</div>
                Use the Audit when you want risk + waste visibility (executive score, priority actions, plan fit).<br /><br />
                <div class="faq-category-badge bg-zinc-50 text-zinc-800 border border-zinc-200">CONTINUITY</div>
                Use the Continuity Report when you’re delivering a project, transferring ownership, documenting for ops, or preparing for due diligence.
              </div>
            </div>
          </div>

          <div class="faq-item">
            <button class="faq-question" aria-expanded="false" onclick="toggleFaq(this)">
              <span class="faq-question-text">Why is the Continuity Report paid?</span>
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
              <div class="faq-answer-inner">
                It’s a client-facing documentation bundle: plain-English per Zap, dependency map, troubleshooting guidance, and a checklist.
                Agencies typically include it as a “Professional Documentation” deliverable.
              </div>
            </div>
          </div>

          <!-- White labeling-->
          <!-- 
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false" onclick="toggleFaq(this)">
              <span class="faq-question-text">Can I brand the reports for clients?</span>
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
