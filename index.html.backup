  <!-- How it works -->
  <section id="how-it-works" class="py-18 bg-white">
    <div class="container mx-auto px-6">
      <div class="max-w-4xl mx-auto text-center mb-12">
        <h2 class="text-3xl md:text-5xl font-black text-zinc-900 mb-4" style="letter-spacing:-0.02em;">
          One export. Two outcomes.
        </h2>
        <p class="text-lg text-zinc-600">~30 seconds. No upload. Processed locally.</p>
      </div>

      <div class="max-w-5xl mx-auto grid md:grid-cols-3 gap-8">
        <div class="text-center bg-white rounded-2xl p-7 border border-zinc-200 shadow-sm card-hover">
          <div class="w-16 h-16 rounded-2xl bg-blue-100 text-blue-600 flex items-center justify-center text-3xl font-black mx-auto mb-4 border border-blue-200">1</div>
          <h3 class="text-xl font-black text-zinc-900 mb-2">Export from Zapier</h3>
          <p class="text-zinc-600">Settings → Data Management → Export. Download the file.</p>
        </div>

        <div class="text-center bg-white rounded-2xl p-7 border border-zinc-200 shadow-sm card-hover">
          <div class="w-16 h-16 rounded-2xl bg-blue-100 text-blue-600 flex items-center justify-center text-3xl font-black mx-auto mb-4 border border-blue-200">2</div>
          <h3 class="text-xl font-black text-zinc-900 mb-2">Open Relay</h3>
          <p class="text-zinc-600">Drop the export into the tool. Nothing leaves your browser.</p>
        </div>

        <div class="text-center bg-white rounded-2xl p-7 border border-zinc-200 shadow-sm card-hover">
          <div class="w-16 h-16 rounded-2xl bg-blue-100 text-blue-600 flex items-center justify-center text-3xl font-black mx-auto mb-4 border border-blue-200">3</div>
          <h3 class="text-xl font-black text-zinc-900 mb-2">Download your PDF</h3>
          <p class="text-zinc-600">Choose Audit or Continuity. Get a clean report in seconds.</p>
        </div>
