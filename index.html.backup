        -->

        <div class="max-w-4xl mx-auto grid md:grid-cols-3 gap-4 text-left">
          <div class="rounded-2xl bg-white/5 border border-white/10 p-5">
            <div class="text-white font-black mb-1">Hidden breakpoints</div>
            <div class="text-slate-300">Find fragile connections, owner-dependency, and “it works until it doesn’t.”</div>
          </div>
          <div class="rounded-2xl bg-white/5 border border-white/10 p-5">
            <div class="text-white font-black mb-1">Waste & task burn</div>
            <div class="text-slate-300">Spot redundant steps and filter placement that silently inflates cost.</div>
          </div>
          <div class="rounded-2xl bg-white/5 border border-white/10 p-5">
            <div class="text-white font-black mb-1">Transfer-ready docs</div>
            <div class="text-slate-300">Deliver a clean handoff package your next owner can actually use.</div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Problem -->
  <section class="py-18 bg-white border-b border-zinc-200">
    <div class="container mx-auto px-6">
      <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-10 items-start">
