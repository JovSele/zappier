      <div class="max-w-5xl mx-auto mt-10 text-center">
        <a href="/app.html#audit" class="inline-flex items-center gap-2 px-8 py-4 bg-blue-600 hover:bg-blue-700 text-white font-black rounded-xl shadow-lg transition-all hover:scale-[1.02]">
          Start with the Free Audit
