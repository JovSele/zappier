        </div>

        <div class="flex flex-wrap justify-center gap-3 mb-10">
          <span class="pill bg-emerald-500/10 text-emerald-200 border border-emerald-500/20">✅ No signup required</span>
          <span class="pill bg-blue-500/10 text-blue-200 border border-blue-500/20">✅ Processed locally</span>
          <span class="pill bg-white/10 text-slate-200 border border-white/15">✅ PDF in seconds</span>
        </div>

