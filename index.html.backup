        </div>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="hero-gradient py-18 md:py-28 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-16 left-10 w-72 h-72 bg-blue-500 rounded-full filter blur-3xl"></div>
      <div class="absolute bottom-16 right-10 w-96 h-96 bg-purple-500 rounded-full filter blur-3xl"></div>
