          <a href="/app.html#audit" class="px-5 py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-black rounded-lg transition-all hover:scale-[1.02]">
            Run Risk Audit (Free)
          </a>
          <a href="/app.html#handoff" class="px-5 py-2.5 bg-zinc-900 hover:bg-zinc-800 text-white font-black rounded-lg transition-all hover:scale-[1.02]">
            Generate Continuity Report ($97)
