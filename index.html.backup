          <a href="/app.html#handoff" class="px-8 py-4 bg-white/10 hover:bg-white/20 text-white text-lg font-black rounded-xl backdrop-blur-sm border border-white/20 transition-all hover:scale-[1.03] inline-flex items-center gap-3">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
            Generate Continuity Report ($97)
