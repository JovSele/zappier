              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <div class="leading-tight">
            <div class="text-xl md:text-2xl font-black text-zinc-900" style="letter-spacing:-0.02em;">Relay</div>
            <div class="text-xs md:text-sm text-zinc-500 font-semibold">Automation Risk & Continuity Reports</div>
