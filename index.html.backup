<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-H6S19G1N29"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-H6S19G1N29');
  </script>

  <title>Relay — Zapier Risk Audit + Continuity Report (100% Private)</title>

  <!-- Your existing Tailwind build -->
  <link rel="stylesheet" href="/src/style.css" />

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');

    body { font-family: 'Inter', sans-serif; }

    .gradient-text {
      background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero-gradient {
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
    }

    .card-hover { transition: all 0.25s ease; }
    .card-hover:hover {
      transform: translateY(-4px);
      box-shadow: 0 20px 25px -5px rgba(0,0,0,0.10), 0 10px 10px -5px rgba(0,0,0,0.04);
    }

    .pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 14px;
      border-radius: 999px;
      font-weight: 700;
      font-size: 0.875rem;
    }

    /* FAQ */
    .faq-item { border-bottom: 1px solid #e4e4e7; }
    .faq-item:last-child { border-bottom: none; }
    .faq-question {
      width: 100%;
      text-align: left;
      padding: 20px 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
      cursor: pointer;
      background: none;
      border: none;
      font-family: 'Inter', sans-serif;
      font-size: 1rem;
      font-weight: 800;
      color: #18181b;
      gap: 16px;
      line-height: 1.4;
    }
    .faq-question:hover { color: #2563eb; }
    .faq-question-text { flex: 1; }
    .faq-icon {
      flex-shrink: 0;
      width: 28px;
      height: 28px;
      border-radius: 999px;
      background: #f4f4f5;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.25s ease;
      color: #71717a;
      font-weight: 900;
    }
    .faq-question[aria-expanded="true"] .faq-icon {
      background: #2563eb;
      color: white;
      transform: rotate(45deg);
    }
    .faq-answer {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.35s ease;
    }
    .faq-answer.open { max-height: 650px; }
    .faq-answer-inner {
      padding-bottom: 20px;
      color: #52525b;
      font-size: 0.95rem;
      line-height: 1.8;
    }
    .faq-answer-inner code {
      background: #f4f4f5;
      padding: 2px 6px;
      border-radius: 4px;
      font-size: 0.875rem;
      color: #3f3f46;
    }
    .faq-category-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 0.72rem;
      font-weight: 900;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 6px 12px;
      border-radius: 999px;
      margin-bottom: 14px;
    }
  </style>
</head>

<body class="bg-[#fafafa]">

  <!-- Navigation -->
  <nav class="bg-white border-b border-zinc-200 sticky top-0 z-50 backdrop-blur-sm bg-white/90">
